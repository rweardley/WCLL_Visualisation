#!/bin/bash
#SBATCH -A FUS166
#SBATCH -p batch
#SBATCH --nodes=4
#SBATCH --ntasks-per-node=8
#SBATCH --cpus-per-task=7
#SBATCH -t 01:00:00
#SBATCH -J resample_test
#SBATCH --exclusive

cd $SLURM_SUBMIT_DIR
date

module load ums ums032 dav-sdk      # frontier
module load gcc-native/14.2 cray-mpich/9.0.1
module load paraview/5.13.3-mpi     # frontier

srun -n $SLURM_NTASKS pvbatch dat_mhd_off_m4_r8_N5.py
