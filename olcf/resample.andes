#!/bin/bash
#SBATCH -A FUS166
##SBATCH -p batch
#SBATCH -p gpu
#SBATCH --nodes=4
#SBATCH --ntasks-per-node=4
#SBATCH --cpus-per-task=7
#SBATCH -t 01:00:00
#SBATCH -J resample_test
#SBATCH --exclusive

cd $SLURM_SUBMIT_DIR
date

module load paraview/5.13.3-osmesa  # andes
# module load ums ums032 dav-sdk      # frontier
# module load paraview/5.13.3-mpi     # frontier

srun -n $SLURM_NTASKS pvbatch resample_test_x400.py
