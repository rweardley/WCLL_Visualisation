#!/bin/bash
#SBATCH -A fus166
#SBATCH -q debug
#SBATCH -t 01:30:00
#SBATCH -N 10
#SBATCH --ntasks-per-node=56
#SBATCH -J tri_m3_N3
#SBATCH -o log_%x-%j.out

module load cray-python/3.11.7

SOURCE_DIR="/lustre/orion/fus166/proj-shared/rweb/tri_m3_N3/"
OUTPUT_DIR="/lustre/orion/fus166/proj-shared/rweb/tri_m3_N3/"
PINK=1
MHDPINK=0
CURRPINK=0
MESH="m3"

srun --cpu-bind=cores --threads-per-core=1 --label python3 split_nek5000.py $SOURCE_DIR $OUTPUT_DIR $PINK $MHDPINK $CURRPINK $MESH